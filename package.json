{
  "name": "kinderz-ecd",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspaces run build",
    "lint": "npm --workspaces run lint",
    "migrate:db": "prisma migrate dev --schema=packages/db/prisma/schema.prisma --name init"
  }
}
