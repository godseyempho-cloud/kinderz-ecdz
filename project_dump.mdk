      },
      ecdCenterId: {
        type: "string",
        required: false,
      },
      districtId: {
        type: "string",
        required: false,
      }
    },
  },

  plugins: [
    admin({
      defaultRole: "ECD_USER", 
    }), 
    nextCookies(), 
  ],
});

