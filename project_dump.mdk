Directory: ./apps/web/actions/invite.ts
Title: invite.ts
---
"use server";

import { prisma } from "@kinderz/db"; 
import { Role } from "@prisma/client";
import * as crypto from "node:crypto"; // Changed to namespace import
import { revalidatePath } from "next/cache";

export async function createInvite(data: {
  email: string;
  role: Role;
  provinceId?: string;
  districtId?: string;
}) {
  try {
    // 1. Generate a secure random token
    const token = crypto.randomBytes(32).toString("hex");
    
    // 2. Set expiry to 7 days from now
    const expiresAt = new Date();
    expiresAt.setDate(expiresAt.getDate() + 7);

    // 3. Create the invite record
    const invite = await prisma.invite.create({
      data: {
        email: data.email.toLowerCase(),
        role: data.role,
        provinceId: data.provinceId || null,
        districtId: data.districtId || null,
        token: token,
        expiresAt: expiresAt,
      },
    });

    // 4. Construct Link
    const inviteLink = `${process.env.NEXT_PUBLIC_APP_URL}/register?token=${token}`;

    revalidatePath("/provincial/districts"); 
    
    return { success: true, link: inviteLink };
  } catch (error) {
    console.error("Invite Error:", error);
    return { success: false, error: "Failed to create invite" };
  }
}

---
Directory: ./apps/web/actions/register.ts
Title: register.ts
---
"use server";

import { prisma } from "@kinderz/db";
import { hash } from "bcryptjs";
import { redirect } from "next/navigation";

export async function registerAuditor(formData: FormData) {
  const token = formData.get("token") as string;
  const name = formData.get("name") as string;
  const password = formData.get("password") as string;

  // 1. Validate Invite
  const invite = await prisma.invite.findUnique({
    where: { token, used: false },
  });

  if (!invite || invite.expiresAt < new Date()) {
    return { error: "Invalid or expired invitation token." };
  }

  try {
    const hashedPassword = await hash(password, 12);

    await prisma.$transaction(async (tx) => {
      // 2. Create User
      const user = await tx.user.create({
        data: {
          email: invite.email,
          name: name,
          role: invite.role,
          provinceId: invite.provinceId,
          districtId: invite.districtId,
          isActive: true,
          emailVerified: true,
        },
      });

      // 3. Create Auth Account
      await tx.account.create({
        data: {
          userId: user.id,
          providerId: "credential",
          accountId: invite.email,
          password: hashedPassword,
        },
      });

      // 4. Burn the invite
      await tx.invite.update({
        where: { id: invite.id },
        data: { used: true },
      });
    });
  } catch (e) {
    console.error(e);
    return { error: "Failed to create account. Email might already be in use." };
  }

  redirect("/login?registered=true");
}

