      <ul className="divide-y">
        {documents.map((doc) => (
          <li key={doc.id} className="py-2 flex justify-between items-center">
            <span>{doc.name}</span>
            <a href={doc.url} target="_blank" className="text-blue-600 underline text-sm">View File</a>
