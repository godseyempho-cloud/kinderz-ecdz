{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "types": ["node", "next"], // <-- added so Node globals (process, crypto) and Next types resolve everywhere

    "baseUrl": ".", // <-- added so paths work relative to repo root
    "paths": {
      "@kinderz/db": ["packages/db/index.ts"] // <-- added alias for db package
    }
  }
}
